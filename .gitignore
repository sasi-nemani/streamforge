__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.env
.venv/

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage

# Runtime state caches (schema fingerprint cache, field registry, watch state)
.streamforge/
venv/

# Live tap output — runtime, not committed
events/*/live/

# Real GitHub event data (contains public issue bodies with potential secret patterns)
events/github/

# Drift reports are runtime output — not committed
drift_reports/

# schemas/ is intentionally NOT ignored — it is the source of truth.
# Schema files are committed and version-controlled ("schema as code").
# Runtime state and raw samples within schemas/ are excluded:
schemas/**/.watch_state/
schemas/**/.samples/
schemas/**/.stable
schemas/**/.streamforge/

# Runtime logs (keep .gitkeep placeholder only)
logs/*.log
logs/*.log.*

# Test coverage
.coverage
htmlcov/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
site.txt
