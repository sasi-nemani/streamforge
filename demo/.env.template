# StreamForge Demo — Environment Variables
# Copy this file to .env and fill in your values:
#   cp demo/.env.template demo/.env

# ── LLM API key (required for schema inference) ───────────────────────────────
# Primary: Groq (fast, 100k tokens/day free)
# Free Groq key at: https://console.groq.com  (takes ~30 seconds to sign up)
GROQ_API_KEY=gsk_your_key_here

# Fallback: OpenRouter (used automatically when Groq quota is exhausted)
# Free key at: https://openrouter.ai  — model: nvidia/nemotron-3-super-120b-a12b:free
# Leave blank to skip OpenRouter and fall back to statistical inference instead.
OPENROUTER_API_KEY=

# ── Kafka broker (default: local Docker Kafka, no changes needed) ─────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── StreamForge log level ─────────────────────────────────────────────────────
STREAMFORGE_LOG_LEVEL=WARNING
